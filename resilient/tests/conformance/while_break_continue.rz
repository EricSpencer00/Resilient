// Conformance case: Stable "Core syntax: while" + "Basic control flow:
// while loops" (STABILITY.md § Feature Stability › Stable). `break` and
// `continue` are core loop-control constructs intrinsic to `while`
// loops' documented behavior; this case pins that `continue` skips the
// rest of the current iteration and `break` exits the loop entirely,
// including a case where `break` fires before the loop's natural bound.
fn main() {
    let mut i = 0;
    let mut sum = 0;
    while i < 10 {
        i = i + 1;
        if i % 2 == 0 {
            continue;
        }
        sum = sum + i;
    }
    println(sum);
    println(i);

    let mut j = 0;
    while j < 1000 {
        if j == 4 {
            break;
        }
        j = j + 1;
    }
    println(j);

    let mut k = 0;
    let mut iters = 0;
    while k < 5 {
        iters = iters + 1;
        k = k + 1;
        if k == 3 {
            break;
        }
    }
    println(iters);
}
main();
