// Conformance case: Stable "Core syntax: fn, return" + "Function call
// syntax" (STABILITY.md § Feature Stability › Stable). `functions_calls.rz`
// covers single-function recursion (factorial) and nested call
// expressions; this case pins mutual recursion between two independently
// declared functions, including the base case at zero.
fn is_even(int n) -> bool {
    if n == 0 {
        return true;
    }
    return is_odd(n - 1);
}

fn is_odd(int n) -> bool {
    if n == 0 {
        return false;
    }
    return is_even(n - 1);
}

fn main() {
    println(is_even(10));
    println(is_odd(10));
    println(is_even(7));
    println(is_odd(7));
    println(is_even(0));
}
main();
