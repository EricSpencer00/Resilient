// Conformance case: Stable "Core syntax: match" + "Basic control flow:
// match expressions on primitives" (STABILITY.md § Feature Stability ›
// Stable). Complements `match_primitives.rz` (literal-pattern match on
// Int/String) with guarded arms (`x if <cond> => ...`) and a match
// statement (not just a match-as-return-expression) on the Bool
// primitive type.
fn classify(int n) -> string {
    return match n {
        x if x < 0 => "negative",
        0 => "zero",
        x if x < 10 => "small",
        _ => "large",
    };
}

fn main() {
    println(classify(-5));
    println(classify(0));
    println(classify(3));
    println(classify(100));

    let flag = true;
    match flag {
        true => println("was true"),
        false => println("was false"),
    }

    let other = false;
    match other {
        true => println("was true"),
        false => println("was false"),
    }
}
main();
