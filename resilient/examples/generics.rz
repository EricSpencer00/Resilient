fn identity<T>(T x) -> T {
    return x;
}

fn first<A, B>(A a, B b) -> A {
    return a;
}

fn second<A, B>(A a, B b) -> B {
    return b;
}

fn main() {
    println(identity(42));
    println(identity("hello"));
    println(identity(true));
    println(first(1, 2));
    println(second("a", "b"));
}
main();
