// RES-552 demo: array_range_int returns max − min (peak-to-peak)
// of a non-empty integer array. Useful for one-shot spread/range
// without computing variance.

fn main() {
    println(array_range_int([1, 2, 3, 4, 5]));
    println(array_range_int([7, 7, 7]));
    println(array_range_int([-3, 5, 1]));
    println(array_range_int([42]));
    println(array_range_int([100, 5, 30, 1, 70]));
}

main();
