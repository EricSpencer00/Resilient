// RES-3162: impl_blocks regression corpus — multiple impls

struct Point {
    x: i32,
    y: i32,
}

impl Point {
    fn distance(&self) -> i32 {
        return self.x + self.y;
    }
}

impl Point {
    fn translate(&mut self, dx: i32, dy: i32) {
        self.x = self.x + dx;
        self.y = self.y + dy;
    }
}

fn main() {
    let mut p = Point { x: 3, y: 4 };
    println(p.distance());
    p.translate(1, 1);
    println(p.distance());
}
