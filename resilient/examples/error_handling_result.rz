// RES-3170: error_handling regression corpus — Result error handling

type Error = String;
type Result<T> = Option<T>;

fn parse_number(s: String) -> Result<i32> {
    if s == "42" {
        return Some(42);
    }
    return None;
}

fn main() {
    let result = parse_number("42");
    match result {
        Some(n) => println(n),
        None => println("error"),
    }
}
