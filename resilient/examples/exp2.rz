// RES-891 demo: exp2(x) returns 2^x. Mirror of exp (e^x).

fn main(int _d) {
    println(exp2(0.0));     // 1
    println(exp2(1.0));     // 2
    println(exp2(2.0));     // 4
    println(exp2(8.0));     // 256
    println(exp2(-1.0));    // 0.5
    println(exp2(-2.0));    // 0.25

    return 0;
}

main(0);
