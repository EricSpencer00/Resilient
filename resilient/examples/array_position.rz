// RES-448 demo: array_position searches from a starting offset.

fn main() {
    let xs = [1, 2, 3, 1, 4, 1, 5];
    println(array_position(xs, 1, 0));
    println(array_position(xs, 1, 1));
    println(array_position(xs, 1, 4));
    println(array_position(xs, 1, 6));
    println(array_position(xs, 99, 0));
}

main();
