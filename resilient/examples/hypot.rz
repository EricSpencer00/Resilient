// RES-892 demo: hypot(x, y) returns sqrt(x² + y²) without intermediate
// overflow. Useful for 2-D distance / vector magnitude.

fn main(int _d) {
    println(hypot(3.0, 4.0));   // 5
    println(hypot(0.0, 0.0));   // 0
    println(hypot(0.0, 5.0));   // 5
    println(hypot(5.0, 12.0));  // 13

    return 0;
}

main(0);
