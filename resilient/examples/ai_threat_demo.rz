// AI Threat Model — demonstration program.
//
// Run with: rz --ai-threats examples/ai_threat_demo.rz
//
// The compiler will report each AI failure-mode pattern present
// in the file, with file:line:col, threat kind, and a suggested
// mitigation. This example showcases detected AI-generated-code patterns.

// OffByOne: loop bounds should use < not <=
fn process_array(Array<int> arr) -> int {
    let i: int = 0;
    while (i <= len(arr)) {  // Should be i < len(arr)
        i = i + 1;
    }
    return i;
}

// MagicNumber: unnamed constants in arithmetic
fn compute_hash(int x) -> int {
    return x * 7919 + 42;  // Named constants are better
}

// UnboundedLoop: while true with no break
fn risky() {
    while true {
        let counter = 0;
        // No break reachable — infinite loop
    }
}

fn main() {
    // Keep the runtime output stable for the golden test while the
    // threat patterns above remain available to `--ai-threats`.
    println(5);
    println(30);
    println(300);
}

main();
