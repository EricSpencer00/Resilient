// RES-159: Match arm guards with if conditions

fn main() {
    let n = 50;

    match n {
        x if x < 0 => println("negative"),
        0 => println("zero"),
        x if x > 100 => println("big"),
        x if x > 50 => println("medium-large"),
        _ => println("small-positive"),
    }

    let value = 75;
    match value {
        x if x % 2 == 0 => println("even"),
        x if x % 2 == 1 => println("odd"),
        _ => println("unknown"),
    }
}

main();
