// RES-2613: Simple benchmark examples.

bench "empty block" {
}

bench "integer arithmetic" {
    let x = 5 + 10;
    let y = x * 2;
    let z = y / 3;
}

bench "string operations" {
    let s = "hello";
    let t = s + " world";
    let u = t + "!";
}

fn fibonacci(int n) -> int {
    if n <= 1 {
        return n;
    }
    return fibonacci(n - 1) + fibonacci(n - 2);
}

bench "fibonacci(10)" {
    fibonacci(10);
}

bench "fibonacci(15)" {
    fibonacci(15);
}
