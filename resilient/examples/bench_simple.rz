// RES-2613: Simple benchmark examples.

bench "empty block" {
}

bench "integer arithmetic" {
    int x = 5 + 10;
    int y = x * 2;
    int z = y / 3;
}

bench "string operations" {
    string s = "hello";
    string t = s + " world";
    string u = t + "!";
}

fn fibonacci(int n) -> int {
    if n <= 1 {
        return n;
    }
    return fibonacci(n - 1) + fibonacci(n - 2);
}

bench "fibonacci(10)" {
    fibonacci(10);
}

bench "fibonacci(15)" {
    fibonacci(15);
}
