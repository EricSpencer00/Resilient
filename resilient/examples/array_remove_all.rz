// RES-467 demo: array_remove_all drops every element matching x.

fn main() {
    println(array_remove_all([1, 2, 1, 3, 1], 1));
    println(array_remove_all([1, 2, 3], 99));
    println(array_remove_all([5, 5, 5], 5));
    println(array_remove_all([], 1));
    println(array_remove_all(["a", "b", "a", "c", "a"], "a"));
}

main();
