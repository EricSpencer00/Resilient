// RES-543 demo: array_max_or / array_min_or fall back to a default
// for empty arrays instead of erroring.

fn main() {
    println(array_max_or([3, 1, 4, 1, 5, 9, 2, 6], -1));
    println(array_min_or([3, 1, 4, 1, 5, 9, 2, 6], -1));
    println(array_max_or([], 999));
    println(array_min_or([], -999));
}

main();
