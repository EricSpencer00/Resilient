// RES-553 demo: array_diff_consec_int returns the n−1 pairwise
// consecutive differences arr[i+1] - arr[i]. Empty or singleton
// input yields an empty array (the natural max(0, n−1) length).

fn main() {
    println(array_diff_consec_int([1, 3, 6, 10]));
    println(array_diff_consec_int([5, 5, 5]));
    println(array_diff_consec_int([10, 7, 3, 0]));
    println(array_diff_consec_int([42]));
    println(array_diff_consec_int([]));
}

main();
