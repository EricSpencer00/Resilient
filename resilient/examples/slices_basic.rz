// RES-3180: slices regression corpus — array slices

fn sum_slice(s: [i32]) -> i32 {
    let mut total = 0;
    for i in s {
        total = total + i;
    }
    return total;
}

fn main() {
    let arr = [1, 2, 3, 4, 5];
    let slice = arr[1..4];
    let result = sum_slice(slice);
    println(result);
}
