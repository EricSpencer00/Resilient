// RES-905 demo: cbrt(x) is the cube root. Sibling of sqrt but with
// total domain (defined for negative inputs). std-only; float-in /
// float-out per RES-130.

fn main(int _d) {
    println(cbrt(0.0));                  // 0
    println(cbrt(8.0));                  // 2
    // cbrt is odd, unlike sqrt.
    println(cbrt(-27.0));                // -3
    println(cbrt(125.0));                // 5

    return 0;
}

main(0);
