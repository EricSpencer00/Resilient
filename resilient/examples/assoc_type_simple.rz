// RES-783 PR1: associated type declarations and implementations — parser support

trait Transport {
    type Message;
    type Error;

    fn send(self) -> int;
}

struct Serial {
    int baudrate,
}

impl Transport for Serial {
    type Message = [u8; 64];
    type Error = int;

    fn send(self) -> int {
        return self.baudrate;
    }
}

fn main() {
    let s = new Serial { baudrate: 115200 };
    s.send();
}

main();
